@inject NavigationManager Navigation
@inject RequestBL RequestBL
@inject TokenHelper TokenHelper
@inject TempMessageService MessageService

<h3 class="task-title">IT Requirements</h3>
<div class="task-underline"></div>

@if (ITRequirementsVM.RequestModelHasError && !string.IsNullOrEmpty(ITRequirementsVM.RequestModelErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @((MarkupString)ITRequirementsVM.RequestModelErrorMessage)
    </div>
}
else
{
    @if (ITRequirementsVM.HasError && !string.IsNullOrEmpty(ITRequirementsVM.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @((MarkupString)ITRequirementsVM.ErrorMessage)
        </div>
    }

    <div class="it-section">
        <!-- Designation -->
        <div class="row mb-3" style="font-size: 17px;">
            <div class="col-auto d-flex align-items-center mb-2">
                <label class="form-label mb-0">Designation:</label>
            </div>
            <div class="col-md-4">
                @if (string.IsNullOrWhiteSpace(ITRequirementsVM.Designation))
                {
                    <div class="text-danger">Please select a Designation in Employee Details.</div>
                }
                else
                {
                    <div class="fw-bold">@ITRequirementsVM.Designation</div>
                }
            </div>
        </div>

        <!-- Infra -->
        <h3 class="task-subtitle mb-3">Infra</h3>

        @if (!FilteredInfraOptions.Any())
        {
            <div class="fst-italic text-muted">-- Not Available --</div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-4 p-3 bg-white">
                @for (int i = 0; i < FilteredInfraOptions.Count; i++)
                {
                    var option = FilteredInfraOptions[i];

                    <div class="form-check d-flex align-items-center border-bottom py-2">
                        <InputCheckbox class="form-check-input me-2" @bind-Value="option.IsSelected" disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" />
                        <label class="form-check-label fs-6 fw-normal @(option.IsSoftRemoved ? "text-decoration-line-through text-muted" : "")">@option.Name</label>

                        @if (!string.IsNullOrEmpty(option.ChangeLabel) && !option.IsSoftRemoved)
                        {
                            <span class="badge ms-3 @(option.ChangeLabel.Contains("added") ? "bg-success" : "bg-danger")">
                                @option.ChangeLabel
                            </span>
                        }

                        @if (option.IsSoftRemoved)
                        {
                            <span class="badge ms-2 bg-danger">Removed</span>
                            <button type="button"
                            class="btn btn-secondary btn-sm ms-2"
                            @onclick="() => UndoRemoveIT(option)"
                            disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" >
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <!-- Applications -->
        <h3 class="task-subtitle mt-3 mb-3">Applications</h3>

        @if (!FilteredApplicationOptions.Any())
        {
            <div class="fst-italic text-muted">-- Not Available --</div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-4 p-3 bg-white">
                @for (int i = 0; i < FilteredApplicationOptions.Count; i++)
                {
                    var option = FilteredApplicationOptions[i];

                    <div class="form-check d-flex align-items-center border-bottom py-2">
                        <InputCheckbox class="form-check-input me-2" @bind-Value="option.IsSelected" disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" />
                        <label class="form-check-label fs-6 fw-normal @(option.IsSoftRemoved ? "text-decoration-line-through text-muted" : "")">@option.Name</label>

                        @if (!string.IsNullOrEmpty(option.ChangeLabel) && !option.IsSoftRemoved)
                        {
                            <span class="badge ms-3 @(option.ChangeLabel.Contains("added") ? "bg-success" : "bg-danger")">
                                @option.ChangeLabel
                            </span>
                        }

                        @if (option.IsSoftRemoved)
                        {
                            <span class="badge ms-2 bg-danger">Removed</span>
                            <button type="button"
                            class="btn btn-secondary btn-sm ms-2"
                            @onclick="() => UndoRemoveIT(option)"
                            disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" >
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }

        <!-- Folder Permissions -->
        <div class="row mb-2 mt-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <h3 class="task-subtitle">Folder Permissions</h3>
                <button type="button" class="btn btn-primary" @onclick="AddFolder" disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)">
                    + Add
                </button>
            </div>
        </div>
        @if (ITRequirementsVM.FolderPermissions != null)
        {
            <table class="table table-bordered">
                <thead class="table-dark text-center">
                    <tr>
                        <th>Folder Name / Path</th>
                        <th>Read</th>
                        <th>Write</th>
                        <th>Delete</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (ITRequirementsVM.FolderPermissions.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No folders added. Click + Add to add folders.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var entry in ITRequirementsVM.FolderPermissions.Select((item, idx) => new { item, idx }))
                        {
                            var folder = entry.item;
                            var i = entry.idx;

                            <tr class="@(folder.IsTempRemoved || folder.IsRemoved ? "table-danger" : "")">
                                <td>
                                    <InputText class="@($"form-control {(folder.IsRemoved ? "text-decoration-line-through text-muted" : "")}")"
                                    @bind-Value="folder.NameOrPath"
                                    placeholder="Enter folder path"
                                    disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" />
                                    <ValidationMessage For="@(() => folder.NameOrPath)" />
                                </td>
                                <td class="text-center">
                                    <InputCheckbox class="form-check-input" @bind-Value="folder.IsRead" disabled />
                                    @if (!string.IsNullOrEmpty(folder.ReadLabel))
                                    {
                                        <span class="badge ms-2 @(folder.ReadLabel.Contains("added") ? "bg-success" : "bg-danger")">
                                            @folder.ReadLabel
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <InputCheckbox class="form-check-input" @bind-Value="folder.IsWrite" disabled="@(folder.IsRemoved || (IsModificationRequest && !RequestModel.ModifyITRequirements))" />
                                    @if (!string.IsNullOrEmpty(folder.WriteLabel))
                                    {
                                        <span class="badge ms-2 @(folder.WriteLabel.Contains("added") ? "bg-success" : "bg-danger")">
                                            @folder.WriteLabel
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <InputCheckbox class="form-check-input" @bind-Value="folder.IsDelete" disabled="@(folder.IsRemoved || (IsModificationRequest && !RequestModel.ModifyITRequirements))" />
                                    @if (!string.IsNullOrEmpty(folder.DeleteLabel))
                                    {
                                        <span class="badge ms-2 @(folder.DeleteLabel.Contains("added") ? "bg-success" : "bg-danger")">
                                            @folder.DeleteLabel
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (folder.IsTempRemoved)
                                    {
                                        <span class="badge bg-danger">@folder.TempStatus</span>
                                    }
                                    else if (folder.IsRemoved)
                                    {
                                        <span class="badge bg-danger">Removed</span>
                                    }
                                    else if (!string.IsNullOrEmpty(folder.Status))
                                    {
                                        <span>@folder.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!(folder.IsTempRemoved || folder.IsRemoved))
                                    {
                                        <button class="btn btn-danger btn-sm"
                                        type="button"
                                        @onclick="() => RemoveFolder(i)"
                                        disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" >
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm"
                                        type="button"
                                        @onclick="() => UndoRemoveFolder(entry.idx)"
                                        disabled="@(IsModificationRequest && !RequestModel.ModifyITRequirements)" >
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public ViewModelITRequirements ITRequirementsVM { get; set; }
    [Parameter, EditorRequired]
    public ViewModelRequest RequestModel { get; set; }

    [Parameter] public string DesignationFromEmployeeDetails { get; set; }
    [Parameter] public int? DesignationIDFromEmployeeDetails { get; set; }

    private List<ITOption> FilteredInfraOptions { get; set; } = new();
    private List<ITOption> FilteredApplicationOptions { get; set; } = new();
    private bool _folderOriginalsInitialized = false;
    private bool _infraOriginalsInitialized = false;
    private bool _appOriginalsInitialized = false;

    protected override void OnParametersSet()
    {
        SetDesignationFromParent();
        FilterOptionsByDesignation();
        SyncSelectionsToViewModel();

        if (!_folderOriginalsInitialized && ITRequirementsVM?.FolderPermissions != null)
        {
            foreach (var folder in ITRequirementsVM.FolderPermissions)
            {
                folder.OriginalRead = folder.IsRead;
                folder.OriginalWrite = folder.IsWrite;
                folder.OriginalDelete = folder.IsDelete;
            }

            _folderOriginalsInitialized = true;
        }
    }

    private void AddFolder()
    {
        try
        {
            ITRequirementsVM.FolderPermissions.Add(new FolderPermission
            {
                IsRead = true,
                Status = "New",
                IsTempRemoved = false,
                IsAdded = true,
                DateAdded = DateTime.Now
            });
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during AddFolder: {ex}");
        }
    }

    private void RemoveFolder(int index)
    {
        if (index >= 0 && index < ITRequirementsVM.FolderPermissions.Count)
        {
            var folder = ITRequirementsVM.FolderPermissions[index];
            bool isExisting = !string.IsNullOrEmpty(folder.NameOrPath) && (folder.OriginalRead || folder.OriginalWrite || folder.OriginalDelete);

            if (isExisting)
            {
                folder.IsTempRemoved = true;
                folder.TempStatus = "To be deleted";
                folder.IsRemoved = true;
                folder.DateRemoved = DateTime.Now;
                folder.IsAdded = false;
                folder.DateAdded = null;
            }
            else
            {
                ITRequirementsVM.FolderPermissions.RemoveAt(index);
            }
        }
    }

    private void UndoRemoveFolder(int index)
    {
        if (index >= 0 && index < ITRequirementsVM.FolderPermissions.Count)
        {
            var folder = ITRequirementsVM.FolderPermissions[index];
            bool isExisting = !string.IsNullOrEmpty(folder.NameOrPath) && (folder.OriginalRead || folder.OriginalWrite || folder.OriginalDelete);

            if (isExisting)
            {
                folder.IsTempRemoved = false;
                folder.TempStatus = ""; // reset
                folder.IsRemoved = false;
                folder.DateRemoved = null;
                folder.IsAdded = true;
                folder.DateAdded = DateTime.Now;
            }
        }
    }

    private void UndoRemoveIT(ITOption option)
    {
        option.IsSoftRemoved = false;
        option.IsSelected = true;

        var existing = ITRequirementsVM.SelectedITRequirements
            .FirstOrDefault(x => x.ItemID == option.ItemID);

        if (existing != null)
        {
            existing.IsRemoved = false;
            existing.DateRemoved = null;
            existing.IsAdded = true;
            existing.DateAdded = DateTime.Now;
        }
    }

    private void SetDesignationFromParent()
    {
        ITRequirementsVM.Designation ??= DesignationFromEmployeeDetails;

        if (DesignationIDFromEmployeeDetails > 0)
        {
            ITRequirementsVM.DesignationID = DesignationIDFromEmployeeDetails.Value;
        }
        else
        {
            ITRequirementsVM.DesignationID = 0;
        }
    }

    private void FilterOptionsByDesignation()
    {
        if (ITRequirementsVM.DesignationID > 0)
        {
            int designationId = ITRequirementsVM.DesignationID;

            FilteredInfraOptions = ITRequirementsVM.InfraOptions
                .Where(opt => opt.DesignationID is null || opt.DesignationID == designationId)
                .ToList();

            FilteredApplicationOptions = ITRequirementsVM.ApplicationOptions
                .Where(opt => opt.DesignationID is null || opt.DesignationID == designationId)
                .ToList();

            if (!_infraOriginalsInitialized)
            {
                foreach (var opt in FilteredInfraOptions)
                    opt.OriginalSelected = opt.IsSelected;

                _infraOriginalsInitialized = true;
            }

            if (!_appOriginalsInitialized)
            {
                foreach (var opt in FilteredApplicationOptions)
                    opt.OriginalSelected = opt.IsSelected;

                _appOriginalsInitialized = true;
            }
        }
        else
        {
            FilteredInfraOptions.Clear();
            FilteredApplicationOptions.Clear();
        }
    }

    public void SyncSelectionsToViewModel()
    {
        var now = DateTime.Now;

        var existing = ITRequirementsVM.SelectedITRequirements.ToDictionary(x => x.ItemID);

        ITRequirementsVM.SelectedITRequirements.Clear();

        void AddOrUpdate(ITOption opt, string type)
        {
            if (existing.TryGetValue(opt.ItemID, out var old))
            {
                ITRequirementsVM.SelectedITRequirements.Add(new ITRequirements
                    {
                        ID = old.ID,
                        ItemID = old.ItemID,
                        ItemTitle = old.ItemTitle ?? opt.Name,
                        Type = old.Type ?? type,
                        IsAdded = old.IsAdded,
                        IsRemoved = false,
                        DateAdded = old.DateAdded ?? now,
                        DateRemoved = null,
                        Remark = old.Remark
                    });
            }
            else
            {
                // New selection
                ITRequirementsVM.SelectedITRequirements.Add(new ITRequirements
                    {
                        ItemID = opt.ItemID,
                        ItemTitle = opt.Name,
                        Type = type,
                        IsAdded = true,
                        DateAdded = now,
                        IsRemoved = false,
                        Remark = string.Empty
                    });
            }
        }

        // Infra
        foreach (var opt in FilteredInfraOptions.Where(o => o.IsSelected))
        {
            AddOrUpdate(opt, ConstantHelper.RequestForm.ITRequirementsType.Infra);
        }

        // Applications
        foreach (var opt in FilteredApplicationOptions.Where(o => o.IsSelected))
        {
            AddOrUpdate(opt, ConstantHelper.RequestForm.ITRequirementsType.Applications);
        }

        // Handle deselections (mark removed)
        foreach (var old in existing.Values)
        {
            bool stillSelected =
                FilteredInfraOptions.Any(o => o.ItemID == old.ItemID && o.IsSelected) ||
                FilteredApplicationOptions.Any(o => o.ItemID == old.ItemID && o.IsSelected);

            if (!stillSelected)
            {
                ITRequirementsVM.SelectedITRequirements.Add(new ITRequirements
                    {
                        ID = old.ID,
                        ItemID = old.ItemID,
                        ItemTitle = old.ItemTitle,
                        Type = old.Type,
                        IsAdded = false,
                        IsRemoved = true,
                        DateAdded = null,
                        DateRemoved = now,
                        Remark = old.Remark
                    });
            }
            else if(old.IsRemoved)
            {
                var opt = FilteredInfraOptions.FirstOrDefault(o => o.ItemID == old.ItemID)
                ?? FilteredApplicationOptions.FirstOrDefault(o => o.ItemID == old.ItemID);
                if (opt != null)
                {
                    opt.IsSoftRemoved = true;
                    opt.IsSelected = false;
                }
            }
        }
    }

    private bool IsModificationRequest =>
        RequestModel != null && UpdateTypeRequests.Contains(RequestModel.RequestType);

    private static readonly HashSet<string> UpdateTypeRequests = new()
    {
        ConstantHelper.RequestForm.RequestType.ModificationRequestType,
        ConstantHelper.RequestForm.RequestType.TransferRequestType,
        ConstantHelper.RequestForm.RequestType.PromotionRequestType
    };
}
