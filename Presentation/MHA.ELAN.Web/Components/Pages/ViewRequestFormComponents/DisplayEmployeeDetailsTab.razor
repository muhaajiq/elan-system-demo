@inject NavigationHelper NavigationHelper

<h3 class="task-title">Employee Details</h3>
<div class="task-underline"></div>

<div class="employee-section">
    <!-- Type -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Type</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="Request.RequestType" class="form-control" readonly />
        </div>
    </div>

    <!-- Company -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Company</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.CompanyTitle" class="form-control" readonly />
        </div>
    </div>

    <!-- Name -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Name</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.EmployeeName" class="form-control" readonly />
        </div>
    </div>

    <!-- Employee ID -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Employee ID</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.EmployeeID" class="form-control" readonly />
        </div>
    </div>

    <!-- Designation -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Designation</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.DesignationTitle" class="form-control" readonly />
        </div>
    </div>

    <!-- Grade -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Grade</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.GradeTitle" class="form-control" readonly />
        </div>
    </div>

    <!-- Department -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Department</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.DepartmentTitle" class="form-control" readonly />
        </div>
    </div>

    <!-- Reporting Manager -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Reporting Manager</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.ReportingManagerName" class="form-control" readonly />
        </div>
    </div>

    <!-- Location -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Location</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.LocationTitle" class="form-control" readonly />
        </div>
    </div>

    <!-- Mobile No -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Mobile No.</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.MobileNo" class="form-control" readonly />
        </div>
    </div>

    <!-- Contract/Temporary Staff -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk me-2">Contract/Temporary Staff</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.ContractTemporaryStaff" class="form-control" readonly />
        </div>
    </div>

    <!-- Joined Date and End Date -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label required-asterisk">Joined Date</label>
        </div>
        <div class="col-md-4">
            @if (EmployeeDetails.EmployeeDetailsVM.JoinedDate != null && EmployeeDetails.EmployeeDetailsVM.JoinedDate != DateTime.MinValue)
            {
                <RadzenDatePicker @bind-Value="EmployeeDetails.EmployeeDetailsVM.JoinedDate" ReadOnly DateFormat="@ConstantHelper.DateFormat.DefaultDateFormat" />
            }
            else
            {
                <input type="text" class="form-control" readonly />
            }
        </div>
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">End Date</label>
        </div>
        <div class="col-md-4">
            @if (EmployeeDetails.EmployeeDetailsVM.EndDate != null && EmployeeDetails.EmployeeDetailsVM.EndDate != DateTime.MinValue)
            {
                <RadzenDatePicker @bind-Value="EmployeeDetails.EmployeeDetailsVM.EndDate" ReadOnly DateFormat="@ConstantHelper.DateFormat.DefaultDateFormat" />
            }
            else
            {
                <input type="text" class="form-control" readonly />
            }
        </div>
    </div>

    <!-- Descriptions -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Description 1</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.Description1" class="form-control" readonly />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Description 2</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.Description2" class="form-control" readonly />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Description 3</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.Description3" class="form-control" readonly />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Description 4</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.Description4" class="form-control" readonly />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Description 5</label>
        </div>
        <div class="col-md-4">
            <InputText @bind-Value="EmployeeDetails.EmployeeDetailsVM.Description5" class="form-control" readonly />
        </div>
    </div>

    <hr />

    <!-- Remarks -->
    <div class="row mb-3">
        <div class="col-md-2 d-flex align-items-center">
            <label class="form-label">Remarks</label>
        </div>
        <div class="col-md-10">
            <InputText @bind-value="EmployeeDetails.EmployeeDetailsVM.Remarks" class="form-control" readonly />
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mb-3 px-3">
        <button type="button" class="btn btn-outline-dark" onclick="@Close">Close</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ViewRequestItem Request { get; set; }
    [Parameter, EditorRequired]
    public ViewModelEmployeeDetails EmployeeDetails { get; set; }

    private void Close()
    {
        NavigationHelper.NavigateTo(NavigationHelper.BuildUrl("/Home"));
    }
}
