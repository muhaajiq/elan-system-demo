@page "/RequestListing"
@attribute [Authorize]
@inject SearchBL searchBL
@inject TokenHelper TokenHelper
@inject LogHelper LogHelper
@inject ProjectHelper ProjectHelper
@inject NavigationHelper NavigationHelper
@inject IJSRuntime JS
@inject IOptions<JSONAppSettings> appSettings

@using MHA.ELAN.Entities
@using Microsoft.EntityFrameworkCore

<PageTitle>eLAN Request Listing</PageTitle>

<h3>eLAN Request Listing</h3>

<RadzenTemplateForm TItem="RequestListingSearchModel" Data="@vm.searchModel" Submit="@SearchAsync">
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Request Reference No" Component="referenceNo" Style="width: 30%" />
            <RadzenTextBox @bind-Value="vm.searchModel.ReferenceNo" Name="referenceNo" Placeholder="Request Reference No" Style="width:70%" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Request Type" Component="requestType" Style="width: 30%" />
            <RadzenDropDown @bind-Value="vm.searchModel.RequestType" Name="requestType" Placeholder="--Select a request type--" Data="@requestType" Style="width:70%" Multiple="true" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Submitted By" Component="submittedBy" Style="width: 30%" />
            <RadzenTextBox @bind-Value="vm.searchModel.SubmittedBy" Name="submittedBy" Placeholder="Submitted By" Style="width:70%" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Workflow Status" Component="workflowStatus" Style="width: 30%" />
            <RadzenDropDown @bind-Value="vm.searchModel.WorkflowStatus" Name="workflowStatus" Placeholder="--Select a workflow status--" Data="@workflowStatuses" Style="width:70%" Multiple="true" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Employee Name" Component="employeeName" Style="width: 30%" />
            <RadzenTextBox @bind-Value="vm.searchModel.EmployeeName" Name="employeeName" Placeholder="Employee Name" Style="width:70%" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Employee ID" Component="employeeId" Style="width: 30%" />
            <RadzenTextBox @bind-Value="vm.searchModel.EmployeeId" Name="employeeId" Placeholder="Employee ID" Style="width:70%" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Designation" Component="designation" Style="width: 30%" />
            <RadzenDropDown @bind-Value="vm.searchModel.Designation" Name="designation" Placeholder="--Select designation(s)--" Data="@designations" TextProperty="@nameof(DropDownListItem.Text)" ValueProperty="@nameof(DropDownListItem.Value)" Style="width:70%" Multiple="true" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Department" Component="department" Style="width: 30%" />
            <RadzenDropDown @bind-Value="vm.searchModel.Department" Name="department" Placeholder="--Select department(s)--" Data="@departments" TextProperty="@nameof(DropDownListItem.Text)" ValueProperty="@nameof(DropDownListItem.Value)" Style="width:70%" Multiple="true" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Created Start Date" Component="createdStartDate" Style="width: 30%" />
            <RadzenDatePicker @bind-Value="vm.searchModel.CreatedStartDate" Name="createdStartDate" Placeholder="@appSettings.Value.DefaultDateFormat" ShowTime="false" Style="width:70%" DateFormat="@appSettings.Value.DefaultDateFormat" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Created End Date" Component="createdEndDate" Style="width: 30%" />
            <RadzenDatePicker @bind-Value="vm.searchModel.CreatedEndDate" Name="createdEndDate" Placeholder="@appSettings.Value.DefaultDateFormat" ShowTime="false" Style="width:70%" DateFormat="@appSettings.Value.DefaultDateFormat" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-12 d-flex align-items-center justify-content-end">
            <RadzenCustomValidator Component="createdEndDate" Validator="@(() => ValidateDates(vm.searchModel.CreatedStartDate, vm.searchModel.CreatedEndDate))" Text="Created End Date must be after Created Start Date!" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Submitted Start Date" Component="submittedStartDate" Style="width: 30%" />
            <RadzenDatePicker @bind-Value="vm.searchModel.SubmittedStartDate" Name="submittedStartDate" Placeholder="@appSettings.Value.DefaultDateFormat" ShowTime="false" Style="width:70%" DateFormat="@appSettings.Value.DefaultDateFormat" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <RadzenLabel Text="Submitted End Date" Component="submittedEndDate" Style="width: 30%" />
            <RadzenDatePicker @bind-Value="vm.searchModel.SubmittedEndDate" Name="submittedEndDate" Placeholder="@appSettings.Value.DefaultDateFormat" ShowTime="false" Style="width:70%" DateFormat="@appSettings.Value.DefaultDateFormat" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-12 d-flex align-items-center justify-content-end">
            <RadzenCustomValidator Component="createdEndDate" Validator="@(() => ValidateDates(vm.searchModel.SubmittedStartDate, vm.searchModel.SubmittedEndDate))" Text="Submitted End Date must be after Submitted Start Date!" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-12 d-flex align-items-center justify-content-end">
            <RadzenLabel Text="Show Inactive List Items" Component="showInactiveItems" />
            <RadzenCheckBox @bind-Value="vm.ShowInactiveItems" Name="showInactiveItems" TValue="bool" Change="LoadMaintenanceListItems" />
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-end">
            <RadzenButton Text="Search" ButtonStyle="ButtonStyle.Primary" Icon="search" Type="Submit" Style="margin-right: 10px" />
            <RadzenButton Text="Clear" ButtonStyle="ButtonStyle.Light" Click="@ClearFilters" Icon="refresh" />
        </div>
    </div>
</RadzenTemplateForm>


<div class="row">
    <div class="col-md-6">
        <p>Search Results</p>
    </div>
    <div class="col-md-6 d-flex justify-content-end">
        <b>Total Search Results: @vm.Count</b>
    </div>
</div>

<RadzenDataGrid @ref="grid"
                TItem="RequestListingData"
                LoadData="@LoadRequestListing"
                AllowPaging="true"
                AllowSorting="true"
                AllowFiltering="false"
                ShowPagingSummary="true"
                PageSize="pageSelectionLimit"
                EmptyText="No data available"
                ColumnWidth="@ConstantHelper.TableColumnWidth.General">
    <Columns>
        <RadzenDataGridColumn TItem="RequestListingData" Title="No." Width="50px" Sortable="false" Frozen="true" WhiteSpace="WhiteSpace.Wrap">
            <Template Context="emp">@(vm.RequestListing.IndexOf(emp) + 1)</Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="RequestListingData" Property="ReferenceNo" Title="Request Reference No" Frozen="true" WhiteSpace="WhiteSpace.Wrap">
            <Template Context="data">
                @{
                    var isDraft = !string.IsNullOrEmpty(data.WorkflowStatus) && data.WorkflowStatus.Equals("Draft", StringComparison.OrdinalIgnoreCase);
                    var isOwner = data.CreatedByLogin?.Equals(vm.CurrentUserLogin, StringComparison.OrdinalIgnoreCase) == true;

                    string url = isDraft && isOwner
                    ? NavigationHelper.BuildUrl("/CreateRequestForm/EmployeeDetails", (ConstantHelper.ParameterQuery.RequestId, data.RequestID.ToString()))
                    : NavigationHelper.BuildUrl("/ViewRequestForm/EmployeeDetails", (ConstantHelper.ParameterQuery.RequestId, data.RequestID.ToString()));
                }

                <a href="@url">@(!string.IsNullOrWhiteSpace(data.ReferenceNo) ? data.ReferenceNo : "-")</a>
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="RequestListingData" Property="EmployeeName" Title="Employee Name" WhiteSpace="WhiteSpace.Wrap" />
        <RadzenDataGridColumn TItem="RequestListingData" Property="EmployeeID" Title="Employee ID" WhiteSpace="WhiteSpace.Wrap" />
        <RadzenDataGridColumn TItem="RequestListingData" Property="RequestType" Title="Request Type" WhiteSpace="WhiteSpace.Wrap" />
        <RadzenDataGridColumn TItem="RequestListingData" Property="Designation" Title="Designation" WhiteSpace="WhiteSpace.Wrap" />
        <RadzenDataGridColumn TItem="RequestListingData" Property="Department" Title="Department" WhiteSpace="WhiteSpace.Wrap" />
        <RadzenDataGridColumn TItem="RequestListingData" Property="WorkflowStatus" Title="Workflow Status" WhiteSpace="WhiteSpace.Wrap" />

        <RadzenDataGridColumn TItem="RequestListingData" Property="CreatedDate" Title="Created Date" WhiteSpace="WhiteSpace.Wrap">
            <Template Context="data">@FormatDate(data.CreatedDate)</Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="RequestListingData" Property="SubmittedDate" Title="Submitted Date" WhiteSpace="WhiteSpace.Wrap">
            <Template Context="data">@FormatDate(data.SubmittedDate)</Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    [SupplyParameterFromQuery(Name = ConstantHelper.ParameterQuery.SPHostUrl)]
    [Parameter]
    public string spHostUrl { get; set; }
    public string accessToken = string.Empty;

    private RadzenDataGrid<RequestListingData> grid;
    public ViewModelRequestListing vm = new();

    List<DropDownListItem> departments = new();
    List<DropDownListItem> designations = new();

    List<string> workflowStatuses = new();

    List<string> requestType = new List<string>
{
    ConstantHelper.RequestForm.RequestType.NewRequestType,
    ConstantHelper.RequestForm.RequestType.ModificationRequestType,
    ConstantHelper.RequestForm.RequestType.TerminationRequestType,
    ConstantHelper.RequestForm.RequestType.TransferRequestType,
    ConstantHelper.RequestForm.RequestType.PromotionRequestType,

};

    private int pageSelectionLimit;

    protected override async Task OnInitializedAsync()
    {
        accessToken = await TokenHelper.GetUserAccessToken();
        pageSelectionLimit = int.Parse(JSONAppSettings.SearchPagingShowLimit);

        // await LoadMaintenanceListItems();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadMaintenanceListItems();
        }
    }

    private async Task LoadMaintenanceListItems()
    {
        await JS.InvokeVoidAsync("showSwalGeneralLoading", "Loading List Items", "Please wait while we are loading list items...");

        bool showInactive = vm.ShowInactiveItems;

        //TODO: Add logic to handle exception
        workflowStatuses = ProjectHelper.GetWorkflowStatus();
        requestType = ProjectHelper.GetRequestType();
        designations = ProjectHelper.LoadDropDownListItem(ConstantHelper.SPList.Designation, showInactive, spHostUrl, accessToken);
        departments = ProjectHelper.LoadDropDownListItem(ConstantHelper.SPList.Department, showInactive, spHostUrl, accessToken);

        await JS.InvokeVoidAsync("Swal.close");
    }

    private async Task LoadRequestListing(LoadDataArgs args)
    {
        try
        {
            await JS.InvokeVoidAsync("showSwalGeneralLoading", "Searching Request", "Please wait while we are loading requests...");

            int pageSize = args.Top ?? pageSelectionLimit;
            int skip = args.Skip ?? 0;
            var currentPage = (skip / pageSize) + 1;

            vm.PageNumber = currentPage;
            vm.RowsPerPage = pageSelectionLimit;
            vm.SortField = args.Sorts?.FirstOrDefault()?.Property;
            vm.SortDirection = args.Sorts?.FirstOrDefault()?.SortOrder.Value.ToString();

            vm = await searchBL.SearchRequestListing(vm, spHostUrl, accessToken);

            grid.Data = vm.RequestListing;
            grid.Count = vm.Count;

            await JS.InvokeVoidAsync("Swal.close");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.close");

            await JS.InvokeVoidAsync("showSwalError", "Failed to load request listing. ");

            LogHelper.LogMessage("RequestBL - SearchRequestListing Error: " + ex.ToString());
        }
    }

    private async Task SearchAsync(RequestListingSearchModel model)
    {
        vm.searchModel = model;

        await grid.Reload();
    }


    private async Task ClearFilters()
    {
        vm.searchModel = new RequestListingSearchModel();

        await grid.Reload();
    }

    string FormatDate(DateTime? date)
    {
        return (date == null || date == DateTime.MinValue)
            ? "-"
            : date.Value.ToString(appSettings.Value.DefaultDateFormat);
    }

    private bool ValidateDates(DateTime? start, DateTime? end)
    {
        if (start.HasValue && end.HasValue && end < start) return false;

        return true;
    }
}
