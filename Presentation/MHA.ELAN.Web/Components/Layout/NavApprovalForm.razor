@inject NavigationManager Navigation
@inject NavigationHelper NavigationHelper
@inject WorkflowStateService WorkflowStateService

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@(@GetSectionUrl("EmployeeDetails"))">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Employee Details
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@(@GetSectionUrl("ITRequirements"))">
                <span class="bi bi-plus-square-fill" aria-hidden="true"></span> IT Requirements
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@(@GetSectionUrl("Hardware"))">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Hardware
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="@(@GetSectionUrl("WorkflowHistory"))">
                <span class="bi bi-clock-history" aria-hidden="true"></span> Workflow History
            </NavLink>
        </div>

        @if (WorkflowStateService.WorkflowStatus == ConstantHelper.WorkflowStatus.PENDING_IT_MANAGER_APPROVAL ||
                WorkflowStateService.WorkflowStatus == ConstantHelper.WorkflowStatus.PENDING_DEPARTMENT_ADMIN_ACTION
                )
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@(@GetSectionUrl("Changes"))">
                    <span class="bi bi-file-diff-fill" aria-hidden="true"></span> Changes
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Parameter]
    public int RequestID { get; set; }

    private string GetSectionUrl(string section)
    {
        return NavigationHelper.BuildUrl($"/ApprovalForm/{section}");
    }
}